<!--pages/merchant-orders/merchant-orders.wxml-->
<view class="orders-page">
  <!-- Tab切换 -->
  <view class="tabs">
    <view class="tab-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-status="1">
      <text class="tab-text">待接单</text>
      <view class="tab-badge" wx:if="{{counts[1] > 0}}">{{counts[1]}}</view>
    </view>
    <view class="tab-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-status="2">
      <text class="tab-text">制作中</text>
    </view>
    <view class="tab-item {{currentTab === 3 ? 'active' : ''}}" bindtap="switchTab" data-status="3">
      <text class="tab-text">已完成</text>
    </view>
    <view class="tab-item {{currentTab === 4 ? 'active' : ''}}" bindtap="switchTab" data-status="4">
      <text class="tab-text">退款</text>
      <view class="tab-badge" wx:if="{{counts[4] > 0}}">{{counts[4]}}</view>
    </view>
  </view>

  <!-- 订单列表 -->
  <scroll-view 
    class="orders-list" 
    scroll-y 
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
  >
    <view class="order-card" wx:for="{{orders}}" wx:key="_id">
      <view class="order-header">
        <view class="order-info">
          <text class="take-no">订单号 {{item.orderNo || item.takeNo || '-'}}</text>
          <text class="table-no">桌号 {{item.tableNo || '-'}}</text>
        </view>
        <view class="order-status {{'status-' + item.status}}">
          <text wx:if="{{item.status == 4}}">退款申请中</text>
          <text wx:if="{{item.status == 5}}">已退款</text>
          <text wx:if="{{item.status != 4 && item.status != 5}}">{{statusText[item.status]}}</text>
        </view>
      </view>
      
      <view class="order-items">
        <view class="item-row" wx:for="{{item.items}}" wx:for-item="dish" wx:key="index">
          <text class="dish-name">{{dish.name}}</text>
          <text class="dish-quantity">x{{dish.quantity}}</text>
          <text class="dish-price">¥{{dish.subtotal ? Number(dish.subtotal).toFixed(2) : '0.00'}}</text>
        </view>
      </view>
      
      <view class="order-footer">
        <text class="order-total">合计: ¥{{item.totalAmount ? Number(item.totalAmount).toFixed(2) : '0.00'}}</text>
        <view class="order-actions">
          <view class="action-btn primary" wx:if="{{item.status == 1}}" catchtap="acceptOrder" data-id="{{item._id}}">接单</view>
          <view class="action-btn success" wx:if="{{item.status == 2}}" catchtap="completeOrder" data-id="{{item._id}}">完成</view>
          <view class="action-btn success" wx:if="{{item.status == 4}}" catchtap="approveRefund" data-id="{{item._id}}">同意退款</view>
          <view class="action-btn danger" wx:if="{{item.status == 4}}" catchtap="rejectRefund" data-id="{{item._id}}">拒绝</view>
        </view>
      </view>
      
      <view class="order-time">
        <text>{{item.createTime || '-'}}</text>
      </view>
    </view>
    
    <view class="empty" wx:if="{{orders.length === 0 && !loading}}">
      <text class="empty-text">暂无订单</text>
    </view>
  </scroll-view>
</view>
