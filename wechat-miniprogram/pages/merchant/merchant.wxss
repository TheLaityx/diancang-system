/* pages/merchant/merchant.wxss */

.merchant-page {
  min-height: 100vh;
  background: #F5F5F5;
}

.merchant-header {
  background: #C68D56;
  padding: 20px 16px;
}

.header-info {
  display: flex;
  align-items: center;
}

.shop-icon {
  width: 56px;
  height: 56px;
  border-radius: 12px;
  margin-right: 12px;
}

.shop-icon-emoji {
  font-size: 40px;
  margin-right: 12px;
}

.shop-detail {
  display: flex;
  flex-direction: column;
}

.shop-name {
  font-size: 20px;
  font-weight: 600;
  color: #fff;
  margin-bottom: 4px;
}

.shop-status {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.8);
}

.quick-actions {
  display: flex;
  padding: 16px;
  gap: 12px;
}

.action-card {
  flex: 1;
  background: #fff;
  border-radius: 12px;
  padding: 20px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon-wrap {
  position: relative;
  width: 44px;
  height: 44px;
  border-radius: 22px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.action-icon-wrap.pending {
  background: #FDF6EC;
}

.action-icon-wrap.dish {
  background: #E1F3D8;
}

.action-icon-wrap.stats {
  background: #F0F5FF;
}

.action-icon {
  width: 24px;
  height: 24px;
}

.action-icon-emoji {
  font-size: 24px;
}

.action-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 18px;
  height: 18px;
  background: #F56C6C;
  border-radius: 9px;
  font-size: 11px;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 5px;
}

.action-text {
  font-size: 13px;
  color: #333;
}

.today-stats {
  background: #fff;
  margin: 0 16px 12px;
  border-radius: 12px;
  padding: 16px;
}

.stats-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 16px;
}

.stats-grid {
  display: flex;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 24px;
  font-weight: 700;
  color: #C68D56;
  margin-bottom: 4px;
}

.stats-label {
  font-size: 12px;
  color: #999;
}

.pending-section {
  margin: 0 16px 12px;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #333;
}

.more-link {
  font-size: 12px;
  color: #999;
}

.pending-list {
  white-space: nowrap;
  height: 140px;
}

.pending-card {
  display: inline-block;
  width: 200px;
  background: #fff;
  border-radius: 12px;
  padding: 12px;
  margin-right: 12px;
  vertical-align: top;
}

.pending-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.take-no {
  font-size: 18px;
  font-weight: 700;
  color: #C68D56;
}

.table-no {
  font-size: 12px;
  color: #666;
}

.pending-items {
  font-size: 12px;
  color: #666;
  margin-bottom: 12px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pending-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.pending-amount {
  font-size: 16px;
  font-weight: 600;
  color: #333;
}

.pending-actions {
  display: flex;
  gap: 8px;
}

.action-btn {
  padding: 6px 16px;
  border-radius: 16px;
  font-size: 12px;
  font-weight: 500;
}

.action-btn.accept {
  background: #C68D56;
  color: #fff;
}

.settings-section {
  background: #fff;
  margin: 12px 16px;
  border-radius: 12px;
}

.settings-item {
  display: flex;
  align-items: center;
  padding: 16px;
}

.settings-icon {
  width: 22px;
  height: 22px;
  margin-right: 12px;
}

.settings-text {
  flex: 1;
  font-size: 15px;
  color: #333;
}

.settings-icon-emoji {
  font-size: 20px;
  margin-right: 12px;
}

.arrow-icon {
  width: 20px;
  height: 20px;
}

.arrow-icon-emoji {
  font-size: 24px;
  color: #999;
}
