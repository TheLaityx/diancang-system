/* pages/refund/refund.wxss */

.refund-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 16px;
}

.refund-form {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.form-item {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 14px;
  font-weight: 600;
  color: #333;
  margin-bottom: 12px;
}

.reason-list {
  margin-bottom: 16px;
}

.reason-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 16px;
  background: #F5F5F5;
  border-radius: 8px;
  margin-bottom: 8px;
}

.reason-item.active {
  background: #FDF6EC;
  border: 1px solid #C68D56;
}

.reason-item text {
  font-size: 14px;
  color: #333;
}

.check-icon {
  color: #C68D56;
  font-weight: 600;
}

.reason-input {
  width: 100%;
  height: 100px;
  padding: 12px;
  background: #F5F5F5;
  border-radius: 8px;
  font-size: 14px;
}

.placeholder {
  color: #999;
}

.submit-btn {
  margin-top: 24px;
  height: 50px;
  background: #C68D56;
  border-radius: 25px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-text {
  font-size: 16px;
  font-weight: 600;
  color: #fff;
}
