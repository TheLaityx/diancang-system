<!--pages/merchant-settings/merchant-settings.wxml-->
<view class="settings-page">
  <view class="settings-section">
    <view class="settings-item" bindtap="changePassword">
      <text class="settings-text">修改登录密码</text>
      <image class="arrow-icon" src="/images/icon-arrow-right.png" mode="aspectFit"></image>
    </view>
  </view>
  
  <view class="logout-section">
    <view class="logout-btn" bindtap="logout">
      <text>退出登录</text>
    </view>
  </view>
</view>
