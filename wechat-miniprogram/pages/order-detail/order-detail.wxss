/* pages/order-detail/order-detail.wxss */

.detail-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 100px;
}

.status-card {
  background: #C68D56;
  padding: 24px 16px;
  color: #fff;
}

.status-header {
  margin-bottom: 16px;
}

.status-text {
  font-size: 20px;
  font-weight: 600;
}

.take-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.take-label {
  font-size: 14px;
  opacity: 0.8;
  margin-bottom: 8px;
}

.take-no {
  font-size: 48px;
  font-weight: 700;
  letter-spacing: 4px;
}

.info-section,
.items-section,
.remark-section,
.pay-section {
  padding: 16px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #999;
  margin-bottom: 12px;
}

.info-card,
.items-card,
.remark-card,
.pay-card {
  background: #fff;
  border-radius: 12px;
  padding: 16px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.info-label {
  font-size: 14px;
  color: #666;
}

.info-value {
  font-size: 14px;
  color: #333;
}

.item-row {
  display: flex;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid #F5F5F5;
}

.item-row:last-child {
  border-bottom: none;
}

.item-image {
  width: 50px;
  height: 50px;
  border-radius: 8px;
  margin-right: 12px;
}

.item-image-placeholder {
  width: 50px;
  height: 50px;
  border-radius: 8px;
  margin-right: 12px;
  background: linear-gradient(135deg, #C68D56 0%, #A67B4B 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.item-image-text {
  font-size: 16px;
  color: #fff;
  font-weight: 500;
}

.item-info {
  flex: 1;
  min-width: 0;
}

.item-name {
  display: block;
  font-size: 14px;
  font-weight: 500;
  color: #333;
  margin-bottom: 4px;
}

.item-specs {
  display: block;
  font-size: 12px;
  color: #999;
}

.item-right {
  text-align: right;
}

.item-quantity {
  display: block;
  font-size: 13px;
  color: #999;
  margin-bottom: 4px;
}

.item-price {
  display: block;
  font-size: 15px;
  font-weight: 500;
  color: #333;
}

.remark-text {
  font-size: 14px;
  color: #666;
  line-height: 1.6;
}

.pay-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.pay-label {
  font-size: 14px;
  color: #666;
}

.pay-value {
  font-size: 14px;
  color: #333;
}

.pay-row.total {
  border-top: 1px solid #F5F5F5;
  margin-top: 8px;
  padding-top: 16px;
}

.pay-row.total .pay-label {
  font-weight: 600;
}

.pay-row.total .pay-value {
  font-size: 20px;
  font-weight: 700;
  color: #C68D56;
}

.action-buttons {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 12px;
  padding: 16px;
  background: #fff;
  padding-bottom: calc(16px + constant(safe-area-inset-bottom));
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 48px;
  border-radius: 24px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 15px;
  font-weight: 500;
}

.action-btn.primary {
  background: #C68D56;
  color: #fff;
}

.action-btn.secondary {
  background: #fff;
  color: #C68D56;
  border: 1px solid #C68D56;
}
