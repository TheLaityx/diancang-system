/* pages/merchant-stats/merchant-stats.wxss */

.stats-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 16px;
}

.today-section,
.refund-section,
.dish-section {
  margin-bottom: 16px;
}

.section-title {
  font-size: 14px;
  font-weight: 600;
  color: #999;
  margin-bottom: 12px;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
}

.stats-card {
  flex: 1;
  min-width: calc(50% - 6px);
  background: #fff;
  border-radius: 12px;
  padding: 20px;
  text-align: center;
}

.stats-value {
  display: block;
  font-size: 28px;
  font-weight: 700;
  color: #C68D56;
  margin-bottom: 8px;
}

.stats-label {
  font-size: 13px;
  color: #666;
}

.dish-list {
  background: #fff;
  border-radius: 12px;
  padding: 0 16px;
}

.dish-item {
  display: flex;
  align-items: center;
  padding: 14px 0;
  border-bottom: 1px solid #F5F5F5;
}

.dish-item:last-child {
  border-bottom: none;
}

.dish-rank {
  width: 28px;
  height: 28px;
  background: #F5F5F5;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 600;
  color: #666;
  margin-right: 12px;
}

.dish-item:nth-child(1) .dish-rank {
  background: #C68D56;
  color: #fff;
}

.dish-item:nth-child(2) .dish-rank {
  background: #E8D5C4;
  color: #A67B4B;
}

.dish-item:nth-child(3) .dish-rank {
  background: #E8D5C4;
  color: #A67B4B;
}

.dish-name {
  flex: 1;
  font-size: 14px;
  color: #333;
}

.dish-sales {
  font-size: 14px;
  font-weight: 600;
  color: #C68D56;
}
