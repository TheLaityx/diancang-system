<!--pages/payment-success/payment-success.wxml-->
<view class="success-page">
  <!-- 成功提示 -->
  <view class="success-header">
    <view class="success-icon-wrap">
      <image class="success-icon" src="/images/icon-success.png" mode="aspectFit"></image>
    </view>
    <text class="success-title">支付成功</text>
  </view>

  <!-- 订单信息 -->
  <view class="take-info">
    <view class="take-card">
      <view class="take-no-label">订单号</view>
      <view class="take-no-value">{{orderNo || takeNo}}</view>
    </view>
    <view class="table-info">
      <text class="table-label">桌号</text>
      <text class="table-value">{{tableNo}} 桌</text>
    </view>
  </view>

  <!-- 电子发票 -->
  <view class="invoice-section">
    <view class="invoice-card">
      <view class="invoice-title">电子发票</view>
      <view class="invoice-info">
        <text class="invoice-label">订单号:</text>
        <text class="invoice-value">{{orderNo || '无'}}</text>
      </view>
      <view class="invoice-info">
        <text class="invoice-label">金额:</text>
        <text class="invoice-value">¥{{totalAmount || '0.00'}}</text>
      </view>
      <view class="invoice-info">
        <text class="invoice-label">开票时间:</text>
        <text class="invoice-value">{{invoiceTime || '无'}}</text>
      </view>
      <view class="invoice-tip">发票将发送到您的微信</view>
    </view>
  </view>

  <!-- 进度状态 -->
  <view class="progress-section">
    <view class="section-title">备餐进度</view>
    <view class="progress-card">
      <view class="progress-step {{status >= 1 ? 'active' : ''}}">
        <view class="step-dot"></view>
        <view class="step-line" wx:if="{{status >= 1}}"></view>
        <text class="step-text">已提交</text>
      </view>
      <view class="progress-step {{status >= 2 ? 'active' : ''}}">
        <view class="step-dot"></view>
        <view class="step-line" wx:if="{{status >= 2}}"></view>
        <text class="step-text">商家接单</text>
      </view>
      <view class="progress-step {{status >= 3 ? 'active' : ''}}">
        <view class="step-dot"></view>
        <text class="step-text">制作中</text>
      </view>
      <view class="progress-step {{status >= 4 ? 'active' : ''}}">
        <view class="step-dot"></view>
        <text class="step-text">已完成</text>
      </view>
    </view>
    <view class="progress-hint" wx:if="{{status < 3}}">
      <text>请等待商家接单制作</text>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button class="action-btn primary" bindtap="viewOrderDetail">查看订单详情</button>
    <button class="action-btn secondary" bindtap="backToMenu">继续点餐</button>
  </view>
</view>
