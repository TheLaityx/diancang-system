/* pages/dish/dish.wxss - 现代化菜品详情页 */

.dish-page {
  min-height: 100vh;
  background: #F4F5F7;
  padding-bottom: 88px;
}

/* ===== 图片区 ===== */
.dish-image {
  width: 100%;
  height: 280px;
  display: block;
}

.dish-image-placeholder {
  width: 100%;
  height: 280px;
  background: linear-gradient(135deg, #FDEBD0 0%, #E8C9A0 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.dish-image-text {
  font-size: 72px;
  line-height: 1;
}

/* ===== 内容卡片 ===== */
.dish-content {
  background: #fff;
  border-radius: 20px 20px 0 0;
  margin-top: -20px;
  position: relative;
  padding: 20px 18px 18px;
  box-shadow: 0 -4px 20px rgba(0,0,0,0.08);
}

.dish-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12px;
}

.dish-name {
  flex: 1;
  font-size: 22px;
  font-weight: 800;
  color: #1A1A2E;
  margin-right: 12px;
  line-height: 1.3;
}

.dish-price {
  display: flex;
  align-items: baseline;
  gap: 2px;
  flex-shrink: 0;
}

.price-symbol {
  font-size: 14px;
  color: #C68D56;
  font-weight: 700;
}

.price-value {
  font-size: 30px;
  color: #C68D56;
  font-weight: 900;
  letter-spacing: -1px;
}

.dish-desc {
  font-size: 14px;
  color: #666;
  line-height: 1.7;
  margin-bottom: 14px;
  padding: 12px 14px;
  background: #F8F8FA;
  border-radius: 10px;
}

.dish-info {
  display: flex;
  gap: 16px;
  padding-top: 4px;
}

.info-item {
  font-size: 13px;
  color: #bbb;
  background: #F4F5F7;
  padding: 4px 10px;
  border-radius: 8px;
}

/* ===== 评价区 ===== */
.review-section {
  background: #fff;
  padding: 18px;
  margin-top: 10px;
}

.review-header {
  margin-bottom: 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.review-title {
  font-size: 16px;
  font-weight: 700;
  color: #1A1A2E;
}

.review-count {
  font-size: 12px;
  color: #999;
}

.review-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.review-item {
  padding: 14px 0;
  border-bottom: 1px solid #F4F5F7;
}

.review-item:last-child {
  border-bottom: none;
}

.review-user {
  display: flex;
  align-items: flex-start;
  margin-bottom: 8px;
  gap: 10px;
}

.review-user-avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: linear-gradient(135deg, #C68D56, #A97240);
  color: #fff;
  font-size: 14px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.review-user-info {
  flex: 1;
}

.review-user-name {
  font-size: 14px;
  color: #555;
  font-weight: 600;
  display: block;
}

.review-rating {
  color: #E0E0E0;
  font-size: 12px;
  letter-spacing: 1px;
  margin-top: 2px;
}

.star-icon.active {
  color: #FAAD14;
}

.review-content {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 6px;
  padding-left: 44px;
}

.review-time {
  font-size: 11px;
  color: #bbb;
  flex-shrink: 0;
  margin-top: 2px;
}

.review-reply {
  margin-left: 44px;
  background: #F8F8FA;
  padding: 10px 12px;
  border-radius: 8px;
  margin-top: 6px;
}

.reply-label {
  font-size: 12px;
  color: #C68D56;
  font-weight: 600;
}

.reply-text {
  font-size: 13px;
  color: #666;
  line-height: 1.5;
}

.review-btn-wrap {
  background: #fff;
  padding: 14px 18px;
  margin-top: 1px;
}

.review-btn-text {
  display: block;
  text-align: center;
  color: #C68D56;
  font-size: 14px;
  font-weight: 600;
  background: rgba(198, 141, 86, 0.1);
  padding: 10px 0;
  border-radius: 12px;
}

.review-btn-text.reviewed {
  color: #52C41A;
  background: rgba(82, 196, 26, 0.1);
}

/* ===== 评价弹窗 ===== */
.review-modal {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 9999;
}

.review-modal-mask {
  position: absolute;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.55);
}

.review-modal-content {
  position: absolute;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 22px 22px 0 0;
  padding: 20px 18px;
  padding-bottom: calc(20px + constant(safe-area-inset-bottom));
  padding-bottom: calc(20px + env(safe-area-inset-bottom));
}

.review-modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.review-modal-title {
  font-size: 18px;
  font-weight: 700;
  color: #1A1A2E;
}

.review-modal-close {
  font-size: 20px;
  color: #bbb;
  padding: 4px 8px;
}

.review-rating-wrap {
  display: flex;
  align-items: center;
  margin-bottom: 16px;
  gap: 12px;
}

.review-rating-label {
  font-size: 14px;
  color: #666;
}

.review-stars {
  display: flex;
  gap: 8px;
}

.star {
  font-size: 28px;
  color: #E0E0E0;
}

.star.active {
  color: #FAAD14;
}

.review-input-wrap {
  margin-bottom: 16px;
}

.review-textarea {
  width: 100%;
  height: 96px;
  border: 1.5px solid #EAEAEE;
  border-radius: 10px;
  padding: 12px;
  font-size: 14px;
  color: #333;
  box-sizing: border-box;
  background: #FAFAFA;
}

.review-submit-btn {
  background: linear-gradient(135deg, #C68D56, #A97240);
  height: 50px;
  border-radius: 25px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(198,141,86,0.4);
}

.review-submit-text {
  color: #fff;
  font-size: 16px;
  font-weight: 700;
}

/* ===== 底部加购栏 ===== */
.add-to-cart {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  gap: 12px;
  height: 72px;
  background: #fff;
  padding: 0 18px;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2px 16px rgba(0,0,0,0.08);
}

.add-to-cart.review-mode {
  justify-content: center;
}

.add-to-cart.review-mode .add-btn {
  flex: 1;
}

.back-btn {
  background: linear-gradient(135deg, #E8C9A0, #D4A373) !important;
  box-shadow: 0 4px 14px rgba(212,163,115,0.4) !important;
}

.delete-btn {
  background: linear-gradient(135deg, #FF7875, #FF4D4F) !important;
  box-shadow: 0 4px 14px rgba(255,77,79,0.4) !important;
}

.quantity-wrap {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.quantity-btn {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F4F5F7;
  border: 1.5px solid #E5E5E5;
}

.quantity-btn text {
  font-size: 20px;
  color: #666;
  font-weight: 400;
  line-height: 1;
  margin-top: -1px;
}

.quantity-value {
  width: 36px;
  text-align: center;
  font-size: 18px;
  font-weight: 700;
  color: #1A1A2E;
}

.add-btn {
  flex: 1;
  height: 50px;
  background: linear-gradient(135deg, #C68D56, #A97240);
  border-radius: 25px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 14px rgba(198,141,86,0.4);
}

.btn-text {
  font-size: 16px;
  font-weight: 700;
  color: #fff;
}

/* ===== 加载中 ===== */
.loading-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100vh;
  font-size: 14px;
  color: #bbb;
}
