<!--pages/dish/dish.wxml-->
<view class="dish-page" wx:if="{{dish}}">
  <view class="dish-image-placeholder" wx:if="{{!dish.image}}">
    <text class="dish-image-text">{{dish.name}}</text>
  </view>
  <image class="dish-image" wx:if="{{dish.image}}" src="{{dish.image}}" mode="aspectFill"></image>
   
  <view class="dish-content">
    <view class="dish-header">
      <text class="dish-name">{{dish.name}}</text>
      <view class="dish-price">
        <text class="price-symbol">¥</text>
        <text class="price-value">{{dish.price ? Number(dish.price).toFixed(2) : '0.00'}}</text>
      </view>
    </view>
    
    <view class="dish-desc" wx:if="{{dish.description}}">
      <text>{{dish.description}}</text>
    </view>
    
    <view class="dish-info">
      <text class="info-item">月售 {{dish.sales || 0}}</text>
      <text class="info-item" wx:if="{{reviewSummary.total > 0}}">{{reviewSummary.avg_rating}}分 · {{reviewSummary.total}}条评价</text>
      <text class="info-item" wx:else>暂无评价</text>
    </view>
  </view>

  <!-- 评价 section -->
  <view class="review-section" wx:if="{{reviews.length > 0 || canReview}}">
    <view class="review-header">
      <text class="review-title">顾客评价</text>
      <text class="review-count" wx:if="{{reviewSummary.total > 0}}">{{reviewSummary.total}}条</text>
    </view>
    <view class="review-list">
      <view class="review-item" wx:for="{{reviews}}" wx:key="id">
        <view class="review-user">
          <view class="review-user-avatar">{{item.user_name ? item.user_name[0] : '匿'}}</view>
          <view class="review-user-info">
            <text class="review-user-name">{{item.user_name || '匿名用户'}}</text>
            <view class="review-rating">
              <text class="star-icon {{i < item.rating ? 'active' : ''}}" wx:for="{{5}}" wx:for-item="s" wx:key="i" wx:for-index="i">★</text>
            </view>
          </view>
          <text class="review-time">{{item.created_at}}</text>
        </view>
        <text class="review-content">{{item.content}}</text>
        <view class="review-reply" wx:if="{{item.reply}}">
          <text class="reply-label">商家回复：</text>
          <text class="reply-text">{{item.reply}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 写评价按钮（仅通过订单跳转进入时显示） -->
  <view class="review-btn-wrap" wx:if="{{canReview}}" bindtap="showReviewModal">
    <text class="review-btn-text">写评价</text>
  </view>

  <!-- 已评价提示（提交后显示） -->
  <view class="review-btn-wrap" wx:if="{{!canReview && hasUserReviewed}}">
    <text class="review-btn-text reviewed">您已评价</text>
  </view>

  <!-- 评价弹窗 -->
  <view class="review-modal" wx:if="{{canReview && showReviewModal}}">
    <view class="review-modal-mask" bindtap="hideReviewModal"></view>
    <view class="review-modal-content">
      <view class="review-modal-header">
        <text class="review-modal-title">写评价</text>
        <text class="review-modal-close" bindtap="hideReviewModal">✕</text>
      </view>
      <view class="review-rating-wrap">
        <text class="review-rating-label">评分</text>
        <view class="review-stars">
          <text wx:for="{{5}}" wx:for-item="star" wx:for-index="i" wx:key="i" data-rating="{{i+1}}" bindtap="setRating" class="star {{i < reviewRating ? 'active' : ''}}">★</text>
        </view>
      </view>
      <view class="review-input-wrap">
        <textarea class="review-textarea" placeholder="分享你的用餐体验..." bindinput="onReviewInput" value="{{reviewContent}}"></textarea>
      </view>
      <view class="review-submit-btn" bindtap="submitReview">
        <text class="review-submit-text">提交评价</text>
      </view>
    </view>
  </view>
  
  <!-- 底部操作栏：评价模式 / 查看已评价模式 隐藏购物车 -->
  <view class="add-to-cart" wx:if="{{!canReview && !viewReview}}">
    <view class="quantity-wrap">
      <view class="quantity-btn" catchtap="decreaseQuantity">
        <text>-</text>
      </view>
      <text class="quantity-value">{{quantity}}</text>
      <view class="quantity-btn" catchtap="increaseQuantity">
        <text>+</text>
      </view>
    </view>
    <view class="add-btn" bindtap="addToCart">
      <text class="btn-text">加入购物车 ¥{{totalPrice}}</text>
    </view>
  </view>
  <!-- 写评价模式：返回按钮 -->
  <view class="add-to-cart review-mode" wx:if="{{canReview}}">
    <view class="add-btn back-btn" bindtap="backToOrder">
      <text class="btn-text">返回订单</text>
    </view>
  </view>
  <!-- 查看已评价模式：删除评价 + 返回按钮 -->
  <view class="add-to-cart review-mode" wx:if="{{viewReview}}">
    <view class="add-btn delete-btn" bindtap="deleteReview">
      <text class="btn-text">删除评价</text>
    </view>
    <view class="add-btn back-btn" bindtap="backToOrder">
      <text class="btn-text">返回订单</text>
    </view>
  </view>
</view>

<view class="loading-wrap" wx:if="{{!dish}}">
  <text>加载中...</text>
</view>
