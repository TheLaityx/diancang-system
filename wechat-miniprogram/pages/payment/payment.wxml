<!--pages/payment/payment.wxml-->
<view class="payment-page">
  <!-- 订单信息 -->
  <view class="order-section">
    <view class="section-title">订单信息</view>
    <view class="order-info-card">
      <view class="info-row">
        <text class="info-label">桌号</text>
        <text class="info-value">{{orderData.tableNo}} 桌</text>
      </view>
    </view>
  </view>

  <!-- 菜品清单 -->
  <view class="items-section">
    <view class="section-title">菜品清单</view>
    <view class="items-card">
      <view class="item-row" wx:for="{{orderData.items}}" wx:key="key">
        <image class="item-image" src="{{item.image || '/images/default-dish.png'}}" mode="aspectFill"></image>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-specs" wx:if="{{item.specs}}">{{item.specs}}</text>
        </view>
        <view class="item-right">
          <text class="item-quantity">x{{item.quantity}}</text>
          <text class="item-price">¥{{item.subtotalText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 备注 -->
  <view class="remark-section">
    <view class="section-title">备注</view>
    <view class="remark-card">
      <input 
        class="remark-input" 
        placeholder="请输入备注信息（可选）" 
        placeholder-class="remark-placeholder"
        bindinput="onRemarkInput"
        value="{{remark}}"
      />
    </view>
  </view>

  <!-- 底部支付栏 -->
  <view class="payment-footer">
    <view class="footer-left">
      <text class="total-label">实付</text>
      <text class="total-value">¥{{totalPrice}}</text>
    </view>
    <view class="footer-right {{submitting ? 'disabled' : ''}}" bindtap="submitPayment">
      <text class="pay-btn">{{submitting ? '处理中...' : '立即支付'}}</text>
    </view>
  </view>

  <!-- ===== 模拟支付确认弹窗 ===== -->
  <view class="pay-modal-mask {{showPayModal ? 'show' : ''}}" catchtap="cancelPay"></view>
  <view class="pay-modal {{showPayModal ? 'show' : ''}}">
    <view class="pay-modal-header">
      <view class="pay-modal-icon">💳</view>
      <text class="pay-modal-title">确认支付</text>
    </view>
    <view class="pay-modal-amount">
      <text class="pay-modal-label">支付金额</text>
      <text class="pay-modal-price">¥{{totalPrice}}</text>
    </view>
    <view class="pay-modal-tip">
      <text>（开发演示模式，点击确认直接完成支付）</text>
    </view>
    <view class="pay-modal-btns">
      <view class="pay-modal-cancel" bindtap="cancelPay">取消</view>
      <view class="pay-modal-confirm" bindtap="confirmPay">确认支付</view>
    </view>
  </view>
</view>

