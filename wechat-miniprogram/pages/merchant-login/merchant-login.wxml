<!--pages/merchant-login/merchant-login.wxml-->
<view class="login-page">
  <view class="login-header">
    <image class="logo" src="/images/logo.png" mode="aspectFit"></image>
    <text class="app-name">扫码点餐系统</text>
    <text class="app-subtitle">商家管理后台</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <image class="form-icon" src="/images/icon-user.png" mode="aspectFit"></image>
      <input 
        class="form-input" 
        type="text"
        placeholder="请输入账号" 
        placeholder-class="input-placeholder"
        bindinput="onUsernameInput"
        value="{{username}}"
      />
    </view>
    <view class="form-item">
      <image class="form-icon" src="/images/icon-password.png" mode="aspectFit"></image>
      <input 
        class="form-input" 
        type="password"
        placeholder="请输入密码" 
        placeholder-class="input-placeholder"
        bindinput="onPasswordInput"
        value="{{password}}"
      />
    </view>
    <view class="form-options">
      <checkbox-group bindchange="onRememberChange">
        <label class="remember-label">
          <checkbox value="remember" checked="{{remember}}" color="#C68D56"/>
          <text class="remember-text">记住密码</text>
        </label>
      </checkbox-group>
    </view>
    <button class="login-btn" bindtap="handleLogin" loading="{{loading}}">登录</button>
  </view>

  <view class="scan-login" bindtap="scanLogin">
    <text class="scan-text">扫码登录</text>
    <image class="scan-icon" src="/images/icon-scan.png" mode="aspectFit"></image>
  </view>
</view>
