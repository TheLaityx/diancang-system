/* pages/merchant-login/merchant-login.wxss */

.login-page {
  min-height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
  padding: 60px 32px 40px;
}

.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60px;
}

.logo {
  width: 80px;
  height: 80px;
  margin-bottom: 16px;
}

.app-name {
  font-size: 24px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8px;
}

.app-subtitle {
  font-size: 14px;
  color: #999;
}

.login-form {
  width: 100%;
}

.form-item {
  display: flex;
  align-items: center;
  height: 56px;
  background: #F5F5F5;
  border-radius: 12px;
  padding: 0 16px;
  margin-bottom: 16px;
}

.form-icon {
  width: 22px;
  height: 22px;
  margin-right: 12px;
}

.form-input {
  flex: 1;
  font-size: 15px;
  color: #333;
}

.input-placeholder {
  color: #999;
}

.form-options {
  margin-bottom: 24px;
}

.remember-label {
  display: flex;
  align-items: center;
}

.remember-text {
  font-size: 14px;
  color: #666;
  margin-left: 8px;
}

.login-btn {
  width: 100%;
  height: 56px;
  background: #C68D56;
  color: #fff;
  font-size: 17px;
  font-weight: 600;
  border-radius: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-btn[loading] {
  opacity: 0.7;
}

.scan-login {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40px;
}

.scan-text {
  font-size: 14px;
  color: #C68D56;
  margin-right: 8px;
}

.scan-icon {
  width: 20px;
  height: 20px;
}
